{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":approveMajorUpdates",
    ":semanticCommitsDisabled",
    ":separateMultipleMajorReleases"
  ],
  "enabledManagers": [
    "docker-compose"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "pinDigests": false,
  "packageRules": [
    {
      "description": "Disable digest-only PRs; we don't pin digests.",
      "matchUpdateTypes": [
        "digest",
        "pinDigest"
      ],
      "enabled": false
    },
    {
      "description": "Apply a baseline soak period to image version bumps.",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Tag docker-compose updates so they're easy to scan in the PR list.",
      "matchManagers": [
        "docker-compose"
      ],
      "addLabels": [
        "docker"
      ]
    },
    {
      "description": "Mark major updates explicitly.",
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ]
    }
  ],
  "prBodyNotes": [
    "{{#if isMajor}}This is a major update. Read the upstream release notes and migration notes before merging.{{/if}}"
  ]
}
