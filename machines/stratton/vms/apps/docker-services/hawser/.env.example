# Dockhand control-plane URL (edge mode, outbound WebSocket).
DOCKHAND_SERVER_URL=wss://dockhand.local.jabbas.dev/api/hawser/connect

# Pairing token. Generated in the Dockhand UI when creating the
# Environment (Settings -> Environments -> Add -> Hawser Edge).
# Shown only once; store securely.
HAWSER_TOKEN=replace-with-token-from-dockhand-ui
