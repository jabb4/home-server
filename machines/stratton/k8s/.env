# Desired Talos version for all nodes. Bootstrap and add-node flows verify the
# live nodes match this version before continuing.
TALOS_VERSION=1.12.6

# Talos Image Factory schematic ID used for upgrades so required system
# extensions like iscsi-tools and util-linux-tools are preserved.
TALOS_SCHEMATIC_ID=88d1f7a5c4f1d3aba7df787c448c1d3d008ed29cfb34af53fa0df4336a56040b

# Talos / Kubernetes cluster name used when generating machine configs.
CLUSTER_NAME=homelab

# Space-separated Talos node names.
CONTROLPLANES=cp-1
WORKERS=worker-1

# Desired final static IPs for the nodes.
CP_1_IP=10.0.20.11
WORKER_1_IP=10.0.20.21

# Stable Kubernetes API VIP on the Services VLAN.
VIP_IP=10.0.20.10

# Canonical age private key path used for local SOPS operations and for
# populating the argocd/sops-age Kubernetes Secret during bootstrap.
SOPS_AGE_KEY_FILE=/Users/jacob/.config/sops/age/keys.txt
